# Configuration d'environnement.
# Copiez ce fichier en « .env » et adaptez les valeurs.
#
# La base de données CIBLE du projet est PostgreSQL.
# (Si DB_NAME n'est pas défini, l'application bascule sur SQLite,
#  utile pour un essai rapide sans serveur — mais PostgreSQL reste
#  la base de production.)

# --- Base de données PostgreSQL ---
DB_NAME=coop_platform
DB_USER=coop_user
DB_PASSWORD=coop_pass
DB_HOST=localhost
DB_PORT=5432

# --- Hôtes autorisés (séparés par des virgules) ---
# ALLOWED_HOSTS=localhost,127.0.0.1

# -----------------------------------------------------------------
# Création de la base sous PostgreSQL (une seule fois) :
#
#   sudo -u postgres psql
#   CREATE USER coop_user WITH PASSWORD 'coop_pass';
#   CREATE DATABASE coop_platform OWNER coop_user;
#   ALTER USER coop_user CREATEDB;   -- nécessaire pour lancer les tests
#   \q
#
# Puis :  python manage.py migrate
# -----------------------------------------------------------------
