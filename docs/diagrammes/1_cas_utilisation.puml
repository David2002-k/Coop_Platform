@startuml
!include _style.iuml
left to right direction
title Diagramme de cas d'utilisation — Plateforme de Gestion des Coopératives Agricoles

actor "Membre\n(Agriculteur)" as Membre
actor "Acheteur" as Acheteur
actor "Formateur" as Formateur
actor "Livreur" as Livreur
actor "Administrateur" as Admin

rectangle "Plateforme de Gestion des Coopératives Agricoles" {
  usecase "S'authentifier" as UC0
  usecase "Déclarer une production" as UC1
  usecase "Suivre une formation" as UC2
  usecase "Consulter le catalogue" as UC3
  usecase "Passer une commande" as UC4
  usecase "Effectuer le paiement" as UC5
  usecase "Consulter ses reçus" as UC6
  usecase "Créer une formation / quiz" as UC7
  usecase "Gérer les livraisons" as UC8
  usecase "Valider les productions" as UC9
  usecase "Gérer les membres" as UC10
  usecase "Gérer le catalogue" as UC11
}

Membre --> UC0
Membre --> UC1
Membre --> UC2

Acheteur --> UC0
Acheteur --> UC3
Acheteur --> UC4
Acheteur --> UC6
UC4 ..> UC5 : <<include>>

Formateur --> UC0
Formateur --> UC7

Livreur --> UC0
Livreur --> UC8

Admin --> UC9
Admin --> UC10
Admin --> UC11
@enduml
